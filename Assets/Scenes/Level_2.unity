  m_Script: {fileID: 11500000, guid: 50e2875fdc0422e4b9227b7196f53e7d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Trigger_Dialogue
  dialogue:
    sentences:
    - "[1]\u0E27\u0E49\u0E32\u0E27.. \u0E21\u0E35\u0E23\u0E49\u0E32\u0E19\u0E19\u0E48\u0E32\u0E2A\u0E19\u0E43\u0E08\u0E2D\u0E22\u0E39\u0E48\u0E15\u0E23\u0E07\u0E19\u0E35\u0E49\u0E08\u0E23\u0E34\u0E07\u0E14\u0E49\u0E27\u0E22\u0E41\u0E2E\u0E30 "
    - "[2]\u0E2A\u0E27\u0E31\u0E2A\u0E14\u0E35\u0E04\u0E48\u0E30 ! \u0E09\u0E31\u0E19\u0E40\u0E1E\u0E34\u0E48\u0E07\u0E22\u0E49\u0E32\u0E22\u0E21\u0E32\u0E2D\u0E22\u0E39\u0E48\u0E17\u0E35\u0E48\u0E40\u0E21\u0E37\u0E2D\u0E07\u0E19\u0E35\u0E49\u0E44\u0E14\u0E49\u0E2A\u0E31\u0E01\u0E1E\u0E31\u0E01
      \u0E40\u0E25\u0E22\u0E25\u0E2D\u0E07 \u0E04\u0E49\u0E19\u0E2B\u0E32\u0E08\u0E32\u0E01\u0E43\u0E19\u0E42\u0E0B\u0E40\u0E0A\u0E35\u0E22\u0E25
      \u0E41\u0E25\u0E49\u0E27\u0E40\u0E08\u0E2D > \u0E23\u0E49\u0E32\u0E19\u0E02\u0E2D\u0E07\u0E04\u0E38\u0E13\u0E1E\u0E2D\u0E14\u0E35 "
    - "[3]\u0E08\u0E30\u0E27\u0E48\u0E32\u0E44\u0E1B\u0E1E\u0E23\u0E38\u0E48\u0E07\u0E19\u0E35\u0E49\u0E01\u0E47\u0E40\u0E1B\u0E34\u0E14\u0E40\u0E17\u0E2D\u0E21\u0E41\u0E25\u0E49\u0E27
      \u0E17\u0E31\u0E49\u0E07\u0E17\u0E35\u0E48\u0E22\u0E31\u0E07\u0E44\u0E21\u0E48\u0E04\u0E48\u0E2D\u0E22\u0E0A\u0E34\u0E19\u0E01\u0E31\u0E1A\u0E40\u0E2A\u0E49\u0E19
      \u0E17\u0E32\u0E07\u0E2B\u0E23\u0E37\u0E2D\u0E17\u0E35\u0E48\u0E40\u0E17\u0E35\u0E48\u0E22\u0E27\u0E40\u0E25\u0E22
      \u0E15\u0E37\u0E48\u0E19\u0E40\u0E15\u0E49\u0E19\u0E08\u0E31\u0E07 "
    - "[2]\u0E16\u0E49\u0E32\u0E21\u0E35\u0E2D\u0E30\u0E44\u0E23\u0E17\u0E35\u0E48\u0E2A\u0E32\u0E21\u0E32\u0E23\u0E16\u0E17\u0E33\u0E43\u0E2B\u0E49\u0E0A\u0E27\u0E19\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E19
      \u0E46 \u0E04\u0E38\u0E22\u0E44\u0E14\u0E49\u0E01\u0E47\u0E19\u0E48\u0E32\u0E2A\u0E19\u0E38\u0E01\u0E14\u0E35
      \u0E19\u0E49\u0E32.."
    - "[3]\u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E27\u0E48\u0E32\u0E0A\u0E48\u0E27\u0E07\u0E19\u0E35\u0E49\u0E25\u0E32\u0E22\u0E08\u0E38\u0E14
      Polka Dots \u0E08\u0E30\u0E01\u0E33\u0E25\u0E31\u0E07\u0E40\u0E1B\u0E47\u0E19\u0E17\u0E35\u0E48\u0E19\u0E34\u0E22\u0E21
      \u0E14\u0E49\u0E27\u0E22\u0E2A\u0E34"
    - "[4]\u0E27\u0E48\u0E32\u0E44\u0E1B\u0E19\u0E31\u0E48\u0E19 \u2026 \u0E41\u0E2E\u0E30\u0E41\u0E2E\u0E30
      \u0E09\u0E31\u0E19\u0E2D\u0E22\u0E32\u0E01\u0E08\u0E30\u0E2A\u0E31\u0E48\u0E07\u0E02\u0E49\u0E32\u0E27\u0E01\u0E25\u0E48\u0E2D\u0E07\u0E2A\u0E33\u0E2B\u0E23\u0E31\u0E1A
      \u0E1E\u0E23\u0E48\u0E38\u0E07\u0E19\u0E35\u0E49 \u0E2B\u0E19\u0E48\u0E2D\u0E22\u0E19\u0E48\u0E30\u0E04\u0E48\u0E30
      \u0E44\u0E14\u0E49\u0E43\u0E0A\u0E48\u0E21\u0E31\u0E49\u0E22\u0E04\u0E30 ? "
